---
layout: layouts/base.njk
---
<article class="post" data-pagefind-body>
  <div class="py-10 pr-0">
    <h1 class="text-9xl leading-none tracking-tighter m-0 mb-1" style="font-size: clamp(2rem, 10vw, 4rem);">
      {{ title }}
    </h1>

    <nav class="inline">

    {% for tag in tags %}
      <a href="/tags/{{ tag }}/" class="tag inline-block uppercase text-xs leading-none py-1 px-2 mr-2 bg-indigo-400 text-white rounded-md no-underline">{{ tag }}</a>
    {% endfor %}
    </nav>

    <time class="post-date" datetime="{{ date | date('DATETIME') }}">
      {{ date | date('HUMAN_DATE') }}
    </time>
  </div>

  <div class="text-lg leading-relaxed 
              [&_p]:max-w-3xl [&_ol]:max-w-3xl [&_ul]:max-w-3xl
              [&_h1]:text-2xl [&_h1]:font-bold [&_h1]:max-w-xs [&_h1]:mb-0 [&_h1]:mt-5
              [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:max-w-xs [&_h2]:mb-3 [&_h2]:mt-5
              [&_h3]:text-2xl [&_h3]:font-bold [&_h3]:max-w-xs [&_h3]:mb-3 [&_h3]:mt-5
              [&_h4]:text-2xl [&_h4]:font-bold [&_h4]:max-w-xs [&_h4]:mb-3 [&_h4]:mt-5
              [&_h5]:text-2xl [&_h5]:font-bold [&_h5]:max-w-xs [&_h5]:mb-3 [&_h5]:mt-5
              [&_h6]:text-2xl [&_h6]:font-bold [&_h6]:max-w-xs [&_h6]:mb-3 [&_h6]:mt-5
              ">
    {{ content | safe }}
  </div>
</article>

<hr>

<nav>
  <ul class="p-0 list-none flex flex-wrap justify-center">
    {%- set previousPost = search.previousPage(url, "type=posts") %}
    {%- if previousPost %}
    <li class="p-10">
      ← Previous: <a href="{{ previousPost.data.url }}" rel="prev">{{ previousPost.data.title }}</a>
    </li>
    {% endif %}

    {%- set nextPost = search.nextPage(url, "type=posts") %}
    {%- if nextPost %}
    <li class="p-10">
      <strong>Next: <a href="{{ nextPost.data.url }}" rel="next">{{ nextPost.data.title }}</a> →</strong>
    </li>
    {% endif %}
  </ul>
</nav>