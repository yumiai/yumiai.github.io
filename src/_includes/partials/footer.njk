<footer id="basement-message" data-pagefind-ignore>
  <div>  
    <img src="{{ site.baseurl }}/assets/images/logo-yumi.svg" ignorepicture alt="Logo" >
    <p>You, Me and A.I.</p>
  </div>
  <p>{{site.description}}</p> 
</footer>

<footer id="social-links" data-pagefind-ignore>
  <div>
    {% for link in site.sociallinks %}
    <div>
      <a href="{{ link.url }}" aria-label="{{ link.title }}"><i class="{{ link.faSet }} {{ link.faIcon }} fa-lg"></i></a>
      <span>{{ link.title }}</span>
    </div>
    {% endfor %}
  </div>
</footer>

<footer id="copyright" data-pagefind-ignore>
  <p>{{site.copyright}}</p>
</footer>