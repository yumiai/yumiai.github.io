<!DOCTYPE html>
<html lang="en" class="text-english-holly bg-coconut-cream">
<head>
    <meta charset="UTF-8">
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">    
    <link rel="shortcut icon" href="{{ site.baseurl }}/assets/images/favico.ico"> 
    <link rel="preconnect" href="https://fonts.gstatic.com">    
    <meta name="viewport" content="initial-scale=1.0, width=device-width, minimum-scale=1.0, viewport-fit=cover">
    <link rel="alternate" href="{{ site.baseurl }}/feed.xml" type="application/atom+xml" title="{{ site.title }}">
    <link rel="alternate" href="{{ site.baseurl }}/feed.json" type="application/json" title="{{ site.title }}">

    <style>
      @charset "UTF-8";   /* Always set Charset. Recommended reading: https://www.w3.org/International/questions/qa-css-charset.en */
      
      @import url('https://fonts.googleapis.com/css2?family=Pacifico&display=swap&text="RedGosithub"'); /* Use font-subsetting wherever it is possible */
      
      @font-face {
          font-family: 'Fraunces';
          src: url('assets/fonts/Fraunces-VariableFont_SOFT\,WONK\,opsz\,wght.ttf') format('truetype');
      }
      @font-face {
          font-family: 'Inter';
          src: url('assets/fonts/Inter-VariableFont_slnt\,wght.ttf') format('truetype');
      }
      
      :root {
      	/* Do not remove or alter the following two lines.           */
      	/* Recommended reading: https://bubblin.io/blog/a-css-router */
      	--portrait-axis: /assets/toucaan/router/portrait.css;
      	--landscape-axis: /assets/toucaan/router/landscape.css;
      }
      
      /* Portrait ⇋ landscape switch. */
      @import url(var(--portrait-axis)) screen and (orientation: portrait);
      @import url(var(--landscape-axis)) screen and (orientation: landscape);
      
      /* --vmin stands for base unit of intrinsic blockscoped typography. */
      @media only screen and (orientation: portrait) {
      	:root {
      		--vmin: calc(100vw/100);
      		/* Fallback if vmin is not supported. */
      	}
      }
      
      @media only screen and (orientation: landscape) {
      	:root {
      		--vmin: calc(100vh/100);
      		/* Fallback if vmin is not supported. */
      	}
      }
      
      /* Global variables below */
      :root {
      	--vmin: 1vmin;
      
      	/* Font families. */
      	--sans-serif: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
      	--system: system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Oxygen, Ubuntu, Cantarell, Droid Sans, Helvetica Neue, Fira Sans, sans-serif !important;
      	--monospace: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      	--serif: -apple-system-ui-serif, ui-serif, "Apple Garamond", "Baskerville", "Times New Roman", "Droid Serif", "Times", "Source Serif Pro", serif;
      	
      	/* Set your custom font unto a variable over here, like so: */
      	--eina-one: 'Eina01 Regular', sans-serif; /* Examples off of Red Goose. See /typopgraphy/typset.scss */
      	--mark-pro-heavy: 'Mark Pro Medium', sans-serif;
      	
      	/****** THE FULL COLOR PALETTE *******/
      	--white: rgba(255, 255, 255, 1);
      	--black: rgba(0, 0, 0, 0);	
      	
      	/* Implement color palette for your brand. { Check → /accessibility/_darkmode.scss as well. }. */
      	/* Recommended reading → Building Your Color Palette by Adam Wathan. https://www.refactoringui.com/previews/building-your-color-palette 	
      
      	--lightmode-primary-text-color: 
      	--lightmode-primary-headings-color: 
      	--lightmode-primary-background-color: 
      	
      	/* Set anchor color 
      	--lightmode-primary-anchor-color: rgba(25, 95, 255, 0.99);
      	--lightmode-primary-anchor-highlighted-color: rgba(50, 140, 255, 0.99);
      
      	
      	/* What this is → TODO: doc link here*/ /*
      	--lightmode-text-selection-color: 
      	--lightmode-background-selection-color: 
      
      	/* What this is → TODO: doc link here*/ /*
      	--lightmode-background-selection-window-inactive-color:
      	--lightmode-text-selection-window-inactive-color:
      
      	/* What this is → TODO: doc link here*/ /*
      	--lightest-grey:
      	--lighter-grey: 
      	--light-grey: 
      	--grey: 
      	--dark-grey:
      	--darker-grey:
      	--darkest-grey: 
      	
      	and so on…*/

        --font-family: 'Inter', -apple-system, system-ui, sans-serif;
	      --red: #c04;
        --lightgray: #e6e6e6;
        --darkgray: #0d1117;
        --blue: #135;
        --white: rgba(255,255,255,0);
      	--text-english-holly: #effef2;
        --bg-coconut-cream: #fcfaed;

      }

      @layer base {
        html,
        body {
          /** Pagefind variables */
          --pagefind-ui-scale: .8;
          --pagefind-ui-primary: var(--darkgray);
          --pagefind-ui-text: var(--darkgray);
          --pagefind-ui-background: var(--white);
          --pagefind-ui-border: var(--darkgray);
          --pagefind-ui-tag: var(--lightgray);
          --pagefind-ui-border-width: 1px;
          --pagefind-ui-border-radius: 6px;
          --pagefind-ui-image-border-radius: 6px;
          --pagefind-ui-image-box-ratio: 3 / 2;
          --pagefind-ui-font: var(--font-family);
      }}

      @layer components {
        /* Navbar */
        #hero-search {
          & .pagefind-ui__drawer { @apply absolute px-5 py-5 overflow-y-auto shadow-lg w-full bg-white border rounded-md max-h-viewport-200 opacity-95}
          & .pagefind-ui__message { @apply m-0 p-0; }
          & .pagefind-ui__result { @apply pt-2 pb-0 border-0 }
          & .pagefind-ui__result-inner { @apply mt-2 }
          & .pagefind-ui__result-link { @apply text-black}
          & .pagefind-ui__result-excerpt { @apply text-gray-500}
        }
      }
    </style>
</head>
<body style="color: var(--text-english-holly); background-color: var(--bg-coconut-cream);">
    <section id="hero-section" class="relative flex flex-col top-0 inset-x-0 overflow-clip">
      <section id="hero-background">
        <div id="hero-background-noise" class="absolute inset-x-0 inset-y-0 grid grid-cols-6 grid-rows-3">
          {% for i in range(0,18) %}
            <div class="grid-item bg-noise blur-2xl invert-[50%] animate-pulse"></div>
          {%- endfor %}   
        </div>
        <div id="hero-background-1" class="absolute inset-x-0 inset-y-0 bg-pattern-1 bg-repeat mix-blend-screen animate-bg-1"></div>
        <div id="hero-background-2" class="absolute inset-x-0 inset-y-0 bg-pattern-2 bg-repeat mix-blend-screen animate-bg-2"></div>
        <img class="absolute bottom-0 right-0 mr-[-6.5rem] pt-20 max-h-[24rem] md:max-h-[32rem]" src="{{ site.baseurl }}/assets/images/pilea-peperomioides.png" imagick="avif webp jpg 800@2" alt="Pilea peperomioides plant, the money plant."></img></picture>
      </section>
      <header role="banner" class="flex top-0 inset-x-0 mx-10 mt-5 z-20">
        <picture id="name" class="flex font-header text-xl mr-4">
          {% if url != "/" %}<a href="/">{% endif %}
            <img src="{{ site.baseurl }}/assets/images/logo-yumi.svg" alt="The yumi logo, two hands held in the shape of a heart." class="w-auto">
          {% if url != "/" %}</a>{% endif %}
        </picture>
        <nav role="navigation" class="flex relative items-center self-stretch h-16">
          <menu role="menu" class="p-0 m-0 list-none flex flex-wrap md:mr-2 gap-x-2 md:gap-x-3 xl:gap-x-8">
          {%- for entry in search.pages("menu.visible=true", "menu.order") %}
            {% if entry.data.url != "/" %}
            <li role="menuitem">
              <a href="{{ entry.data.url }}" class="block no-underline hover:text-tuscany hover:underline{% if entry.data.url == url %} font-bold underline" aria-current="page{% endif %}">
                {{ entry.data.menu.title or entry.data.title }}
              </a>
            </li>
            {% endif %}            
          {%- endfor %}
          </menu>
        </nav>
        <div id="hero-search" role="search" class="hidden md:flex md:grow-0 max-w-sm ml-auto"></div>
      </header>

      <section id="hero-message" class="flex flex-col w-7/12 lg:w-8/12 pl-10 pb-16 md:pb-32 mt-16 z-10">
        <h1 class="flex flex-col md:flex-row md:items-center">
          <span class="font-header text-english-holly text-2xl md:text-3xl lg:text-5xl xl:text-6xl whitespace-nowrap">People. Actions.</span>
          <span id="scroll-mask" class="mask-radial w-full mt-[-1.3rem] md:mt-0 md:ml-2 overflow-y-clip">
            <div id="scroll-container" class="flex flex-col-reverse font-serif text-2xl md:text-3xl lg:text-5xl xl:text-6xl gap-0 pl-0 md:ml-1 mt-[-2rem] md:mt-[-2.2rem] lg:mt-[-3rem] xl:mt-[-3.8rem]"></div>
          </span>
        </h1>
        <p class="xl:flex xl:flex-col text-xs md:text-lg lg:text-xl xl:text-2xl mt-[-0.7rem] md:mt-[-1rem] xl:mt-0">
          <span>Unleashing our collective intelligence to propel impactful change.</span>
          <span>Regenerative Finance (ReFi) engineered on Cardano.</span>
        </p>
      </section>
    
    </section>

    <main class="z-30">
  
      <section class="bg-coconut-cream">
        <img src="{{ site.baseurl }}/assets/images/pilea-peperomioides.png" imagick="avif webp jpg 800@2" alt="Pilea peperomioides plant, the money plant."></img>
      </section>

      <section>
        <div class="flex flex-col items-center justify-center opacity-50">
          <div class="flex justify-center items-center mt-2">
            {% for link in site.sociallinks %}
            <div class="flex flex-col items-center justify-center p-3">
              <a href="{{ link.url }}" class="text-xs md:text-base text-gray-700 hover:text-gray-800" aria-label="{{ link.title }}">
                <i class="{{ link.faSet }} {{ link.faIcon }} fa-lg"></i>
              </a>
              <p>{{ link.title }}</p>
            </div>
            {% endfor %}
          </div>
          <img class="block h-6 md:h-8 mt-2 mb-2" src="{{ site.baseurl }}/assets/images/logo-yumi.svg" alt="Logo" >
          <div class="font-header text-base lg:text-lg mt-2">You, Me and A.I.</div>
          <div class="text-xs md:text-base text-center w-7/12">{{site.description}}</div>
        </div>
      </section>

    </main>

    <footer class="bottom-5 mt-2">
        <div class="text-center w-screen text-xs font-fine-print italic">{{site.copyright}}</div>
      </div>
    </footer>

    <script>
      // Add a random animation-delay to each .grid-item div for the background animation.
      document.addEventListener("DOMContentLoaded", function() {
        const gridItems = document.querySelectorAll('.grid-item');
    
        gridItems.forEach(item => {
          const randomDelay = Math.floor(Math.random() * 10);  // random delay between 0 and 5 seconds
          item.style.animationDelay = `${randomDelay}s`;
        });
      });
    </script>

    <script src="{{ site.baseurl }}/assets/scripts/word-scroll.js"></script>

</body>
</html>